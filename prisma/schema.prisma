generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
}

enum LeadStage {
  NEW
  CONTACTED
  FOLLOW_UP
  INTERESTED
  NOT_INTERESTED
  NO_RESPONSE
  CONVERTED
  CLOSED
}

enum LeadActivityType {
  ASSIGNMENT_CHANGE
  STAGE_CHANGE
  NOTE_ADDED
  FOLLOW_UP_UPDATE
  SYSTEM_SYNC
  CREATION
}

enum SheetConnectionStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
}

enum CallEventType {
  RINGING
  ANSWERED
  ENDED
  MISSED
}

enum CallSessionStatus {
  RINGING
  ANSWERED
  MISSED
  COMPLETED
}

enum CallDirection {
  INCOMING
  OUTGOING
  UNKNOWN
}

enum CallLeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  INTERESTED
  NOT_INTERESTED
  NO_RESPONSE
  CONVERTED
  CLOSED
}

enum CallActivityType {
  CALL_CREATED
  CALL_RINGING
  CALL_ANSWERED
  CALL_MISSED
  CALL_COMPLETED
  ASSIGNMENT_CHANGE
  NOTE_ADDED
  FOLLOW_UP_UPDATE
}

model User {
  id           String @id @default(cuid())
  username     String @map("name")
  email        String @unique
  passwordHash String @map("password")
  role         Role   @default(USER)
  department   String @default("Other")

  assignedTasks Task[]        @relation("AssignedTasks")
  createdTasks  Task[]        @relation("CreatedTasks")
  taskComments  TaskComment[]

  websiteLeads   WebsiteLead[]   @relation("WebsiteLeads")
  instagramLeads InstagramLead[] @relation("InstagramLeads")
  leadActivities LeadActivity[]  @relation("UserActivities")
  callLeads      CallLead[]      @relation("CallLeads")
  callSessions   CallSession[]   @relation("CallSessions")
  callActivities CallActivity[]  @relation("CallActivities")
  callFollowUps  CallFollowUp[]  @relation("CallFollowUps")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  assignedToId String
  assignedById String

  assignedTo User          @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedBy User          @relation("CreatedTasks", fields: [assignedById], references: [id], onDelete: Cascade)
  comments   TaskComment[]

  websiteLeadId String?      @map("website_lead_id")
  websiteLead   WebsiteLead? @relation("WebsiteLeadTasks", fields: [websiteLeadId], references: [id], onDelete: SetNull)

  instagramLeadId String?        @map("instagram_lead_id")
  instagramLead   InstagramLead? @relation("InstagramLeadTasks", fields: [instagramLeadId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([assignedToId, status])
  @@index([assignedToId, dueDate])
  @@index([assignedById])
  @@index([status])
  @@index([dueDate])
  @@index([websiteLeadId])
  @@index([instagramLeadId])
}

model TaskComment {
  id       String @id @default(cuid())
  body     String
  taskId   String
  authorId String

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([authorId])
}

model LeadIntegration {
  id            String                @id @default(cuid())
  source        LeadSource            @unique
  appScriptUrl  String?
  spreadsheetId String?
  sheetName     String
  secretToken   String?
  status        SheetConnectionStatus @default(NOT_CONNECTED)
  lastTestedAt  DateTime?
  lastSyncedAt  DateTime?
  importedCount Int                   @default(0)
  failedCount   Int                   @default(0)
  lastError     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebsiteLead {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  atmId     String?  @unique @map("atm_id")

  name          String
  email         String?
  phone         String?
  city          String?
  address       String? @db.Text
  ownershipType String? @map("ownership_type")
  provider      String?
  language      String?
  message       String? @db.Text
  sheetSource   String? @map("sheet_source")

  stage        LeadStage @default(NEW)
  assignedToId String?   @map("assigned_to_id")
  assignedTo   User?     @relation("WebsiteLeads", fields: [assignedToId], references: [id], onDelete: SetNull)

  activities LeadActivity[] @relation("WebsiteLeadActivities")
  tasks      Task[]         @relation("WebsiteLeadTasks")

  lastContactedAt DateTime? @map("last_contacted_at")
  nextFollowUpAt  DateTime? @map("next_follow_up_at")
  notes           String?   @db.Text
  readAt          DateTime? @map("read_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([assignedToId])
  @@index([assignedToId, stage])
  @@index([atmId])
  @@index([readAt])
}

model InstagramLead {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  atmId     String?  @unique @map("atm_id")

  name          String
  email         String?
  phone         String?
  city          String?
  address       String? @db.Text
  ownershipType String? @map("ownership_type")
  provider      String?
  language      String?
  message       String? @db.Text
  sheetSource   String? @map("sheet_source")

  stage        LeadStage @default(NEW)
  assignedToId String?   @map("assigned_to_id")
  assignedTo   User?     @relation("InstagramLeads", fields: [assignedToId], references: [id], onDelete: SetNull)

  activities LeadActivity[] @relation("InstagramLeadActivities")
  tasks      Task[]         @relation("InstagramLeadTasks")

  lastContactedAt DateTime? @map("last_contacted_at")
  nextFollowUpAt  DateTime? @map("next_follow_up_at")
  notes           String?   @db.Text
  readAt          DateTime? @map("read_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([assignedToId])
  @@index([assignedToId, stage])
  @@index([atmId])
  @@index([readAt])
}

model LeadActivity {
  id          String           @id @default(cuid())
  actionType  LeadActivityType @map("action_type")
  description String

  userId String? @map("user_id")
  user   User?   @relation("UserActivities", fields: [userId], references: [id], onDelete: SetNull)

  websiteLeadId String?      @map("website_lead_id")
  websiteLead   WebsiteLead? @relation("WebsiteLeadActivities", fields: [websiteLeadId], references: [id], onDelete: Cascade)

  instagramLeadId String?        @map("instagram_lead_id")
  instagramLead   InstagramLead? @relation("InstagramLeadActivities", fields: [instagramLeadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([websiteLeadId])
  @@index([instagramLeadId])
  @@index([userId])
}

model CompanyPhone {
  id            String    @id @default(cuid())
  phoneNumber   String    @unique @map("phone_number")
  label         String
  deviceId      String    @unique @map("device_id")
  authTokenHash String    @map("auth_token_hash")
  lastSeenAt    DateTime? @map("last_seen_at")
  isActive      Boolean   @default(true) @map("is_active")
  appVersion    String?   @map("app_version")
  androidVersion String?  @map("android_version")
  deviceModel   String?   @map("device_model")
  batteryPercent Int?     @map("battery_percent")
  networkType   String?   @map("network_type")
  pendingSyncCount Int?   @map("pending_sync_count")
  permissionStatus Json?  @map("permission_status")

  events   CallEvent[]
  sessions CallSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([deviceId])
  @@index([phoneNumber])
}

model CallLead {
  id              String         @id @default(cuid())
  phone           String         @unique
  displayName     String         @map("display_name")
  email           String?
  city            String?
  address         String?        @db.Text
  ownershipType   String?        @map("ownership_type")
  provider        String?
  language        String?
  message         String?        @db.Text
  status          CallLeadStatus @default(NEW)
  assignedToId    String?        @map("assigned_to_id")
  assignedTo      User?          @relation("CallLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  firstCompanyPhone String?      @map("first_company_phone")
  lastCompanyPhone  String?      @map("last_company_phone")
  lastContactedAt DateTime?      @map("last_contacted_at")
  nextFollowUpAt  DateTime?      @map("next_follow_up_at")
  instagramLeadId String?        @map("instagram_lead_id")
  sheetSyncedAt   DateTime?      @map("sheet_synced_at")
  sheetSyncWarning String?       @map("sheet_sync_warning") @db.Text
  notes           String?        @db.Text
  isImportant     Boolean        @default(false) @map("is_important")
  locationSent    Boolean        @default(false) @map("location_sent")

  sessions   CallSession[]
  activities CallActivity[]
  followUps  CallFollowUp[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([assignedToId])
  @@index([assignedToId, status])
  @@index([assignedToId, sheetSyncedAt])
  @@index([status, updatedAt])
  @@index([nextFollowUpAt])
  @@index([instagramLeadId])
  @@index([isImportant])
  @@index([locationSent])
}

model CallEvent {
  id             String        @id @default(cuid())
  eventId        String        @unique @map("event_id")
  localSessionId String?       @map("local_session_id")
  companyPhoneId String        @map("company_phone_id")
  companyPhone   CompanyPhone  @relation(fields: [companyPhoneId], references: [id], onDelete: Cascade)
  sessionId      String?       @map("session_id")
  session        CallSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  callerNumber   String        @map("caller_number")
  eventType      CallEventType @map("event_type")
  callDirection  CallDirection @default(INCOMING) @map("call_direction")
  occurredAt     DateTime      @map("occurred_at")
  receivedAt     DateTime      @default(now()) @map("received_at")
  durationSeconds Int?         @map("duration_seconds")
  rawPayload     Json          @map("raw_payload")

  @@index([companyPhoneId])
  @@index([sessionId])
  @@index([localSessionId])
  @@index([callerNumber])
  @@index([eventType])
  @@index([occurredAt])
}

model CallSession {
  id             String            @id @default(cuid())
  localSessionId String?           @map("local_session_id")
  companyPhoneId String            @map("company_phone_id")
  companyPhone   CompanyPhone      @relation(fields: [companyPhoneId], references: [id], onDelete: Cascade)
  callerNumber   String            @map("caller_number")
  leadId         String            @map("lead_id")
  lead           CallLead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status         CallSessionStatus @default(RINGING)
  callDirection  CallDirection     @default(INCOMING) @map("call_direction")
  firstRingAt    DateTime          @map("first_ring_at")
  answeredAt     DateTime?         @map("answered_at")
  endedAt        DateTime?         @map("ended_at")
  durationSeconds Int?             @map("duration_seconds")
  androidCallLogId String?         @map("android_call_log_id")
  simSlot        Int?              @map("sim_slot")
  assignedToId   String?           @map("assigned_to_id")
  assignedTo     User?             @relation("CallSessions", fields: [assignedToId], references: [id], onDelete: SetNull)

  events     CallEvent[]
  activities CallActivity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyPhoneId])
  @@index([localSessionId])
  @@index([callerNumber])
  @@index([leadId])
  @@index([status])
  @@index([status, endedAt])
  @@index([status, firstRingAt])
  @@index([callDirection, firstRingAt])
  @@index([assignedToId])
  @@index([assignedToId, firstRingAt])
  @@index([firstRingAt])
}

model CallActivity {
  id          String           @id @default(cuid())
  leadId      String           @map("lead_id")
  lead        CallLead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sessionId   String?          @map("session_id")
  session     CallSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  actionType  CallActivityType @map("action_type")
  description String
  userId      String?          @map("user_id")
  user        User?            @relation("CallActivities", fields: [userId], references: [id], onDelete: SetNull)
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@index([leadId, createdAt])
  @@index([sessionId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, actionType, createdAt])
  @@index([actionType])
}

model CallFollowUp {
  id           String   @id @default(cuid())
  leadId       String   @map("lead_id")
  lead         CallLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId String?  @map("assigned_to_id")
  assignedTo   User?    @relation("CallFollowUps", fields: [assignedToId], references: [id], onDelete: SetNull)
  dueAt        DateTime @map("due_at")
  completedAt  DateTime? @map("completed_at")
  note         String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([assignedToId])
  @@index([assignedToId, completedAt])
  @@index([dueAt])
  @@index([completedAt])
}
