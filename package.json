{
  "name": "crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"next,worker\" --prefix-colors \"cyan,green\" \"next dev\" \"node scripts/whatsapp-worker.mjs\"",
    "dev:next": "next dev",
    "dev:worker": "node scripts/whatsapp-worker.mjs",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "start:prod": "pm2 start ecosystem.config.js",
    "stop:prod": "pm2 stop ecosystem.config.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run prisma:validate && npm run lint && npm run typecheck && npm run build",
    "test": "npm run check",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed:admin": "node prisma/seed-admin.mjs",
    "whatsapp:worker": "node scripts/whatsapp-worker.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
